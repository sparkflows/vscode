    {"name":"partitionColNames", "value": "[]", "widget": "variables", "title": "Partition Column Names", "description": "Partition Column Names"},

    {"name":"createDataset", "value":"false", "widget": "array_single", "optionsArray": ["true","false"], "title": "Auto create dataset", "description": "Select Models"},
