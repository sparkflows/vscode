      "size":"50%"},

    {"name":"percent","value":"false","widget":"array","title":"Use percent",
      "optionsArray":["true","false"],
      "description":"Select true to present data in percent",
      "datatypes":["boolean"],
      "size":"50%"},

    {"name":"xCol","value":"","widget":"variable","title":"X Column","required":true,"size":"50%"},
    {"name":"groupByCol","value":"","widget":"variable","title":"Group by Column","required":true,"size":"50%"},

    {"name":"yCol","value":"","widget":"variable",
